# ComplianceInvoice - Environment Configuration
# SMB e-Invoicing Compliance SaaS for Multi-Country Mandates

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
VITE_APP_NAME=ComplianceInvoice
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development
NODE_ENV=development
VITE_DEBUG_MODE=false

# ============================================================================
# API CONFIGURATION
# ============================================================================
VITE_API_BASE_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000
VITE_API_RETRY_ATTEMPTS=3
VITE_API_RETRY_DELAY=1000

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
VITE_AUTH_API_URL=http://localhost:3000/api/auth
VITE_AUTH_TOKEN_STORAGE_KEY=compliance_invoice_token
VITE_AUTH_REFRESH_TOKEN_STORAGE_KEY=compliance_invoice_refresh_token
VITE_JWT_SECRET=your_jwt_secret_key_here
VITE_SESSION_TIMEOUT=3600000
VITE_ENABLE_SSO=false
VITE_SSO_PROVIDER=

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/compliance_invoice
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=30000
DATABASE_LOGGING=false

# ============================================================================
# MULTI-COUNTRY COMPLIANCE & TAX SETTINGS
# ============================================================================
VITE_DEFAULT_COUNTRY=US
VITE_DEFAULT_CURRENCY=USD
VITE_SUPPORTED_COUNTRIES=US,GB,DE,FR,IT,ES,NL,BE,AT,SE,DK,PL,CZ,HU,RO,PT,GR,IE,FI,NO,CH
VITE_TAX_CONFIGURATION_API=http://localhost:3000/api/tax-config
VITE_ENABLE_VAT_COMPLIANCE=true
VITE_ENABLE_GST_COMPLIANCE=true
VITE_ENABLE_INTRASTAT_REPORTING=true

# ============================================================================
# E-INVOICING MANDATE COMPLIANCE
# ============================================================================
VITE_ENABLE_PEPPOL=true
VITE_ENABLE_UBL=true
VITE_ENABLE_CFONB=false
VITE_ENABLE_FACTURX=false
VITE_ENABLE_XRECHNUNG=false
VITE_ENABLE_FATTURAPA=false
VITE_ENABLE_EINVOICE_EU=false
VITE_PEPPOL_NETWORK_ENDPOINT=https://peppol-sandbox.example.com
VITE_UBLEQ_ENDPOINT=https://ubleq.example.com

# ============================================================================
# FILE UPLOAD & STORAGE
# ============================================================================
VITE_STORAGE_TYPE=s3
VITE_STORAGE_BUCKET=compliance-invoice-files
VITE_STORAGE_REGION=us-east-1
VITE_STORAGE_KEY_ID=
VITE_STORAGE_SECRET_KEY=
VITE_STORAGE_MAX_FILE_SIZE=10485760
VITE_STORAGE_ALLOWED_EXTENSIONS=pdf,xml,json,csv
VITE_LOCAL_UPLOAD_PATH=./uploads

# ============================================================================
# EMAIL & NOTIFICATION SETTINGS
# ============================================================================
VITE_EMAIL_PROVIDER=sendgrid
VITE_SENDGRID_API_KEY=
VITE_SMTP_HOST=localhost
VITE_SMTP_PORT=587
VITE_SMTP_USER=
VITE_SMTP_PASSWORD=
VITE_SMTP_FROM_EMAIL=noreply@complianceinvoice.com
VITE_SMTP_FROM_NAME=ComplianceInvoice
VITE_ENABLE_EMAIL_NOTIFICATIONS=true
VITE_ENABLE_WEBHOOK_NOTIFICATIONS=true
VITE_NOTIFICATION_QUEUE_TYPE=redis

# ============================================================================
# WEBHOOK & INTEGRATION SETTINGS
# ============================================================================
VITE_WEBHOOK_SECRET=your_webhook_secret_here
VITE_WEBHOOK_RETRY_ATTEMPTS=5
VITE_WEBHOOK_RETRY_DELAY=10000
VITE_ENABLE_ZAPIER_INTEGRATION=false
VITE_ENABLE_MAKE_INTEGRATION=false
VITE_ENABLE_CUSTOM_WEBHOOKS=true
VITE_WEBHOOK_TIMEOUT=30000

# ============================================================================
# ACCOUNTING SYSTEM INTEGRATIONS
# ============================================================================
VITE_ENABLE_QUICKBOOKS_INTEGRATION=false
VITE_QUICKBOOKS_CLIENT_ID=
VITE_QUICKBOOKS_CLIENT_SECRET=
VITE_QUICKBOOKS_REALM_ID=

VITE_ENABLE_XERO_INTEGRATION=false
VITE_XERO_CLIENT_ID=
VITE_XERO_CLIENT_SECRET=

VITE_ENABLE_SAGE_INTEGRATION=false
VITE_SAGE_API_KEY=

VITE_ENABLE_WAVE_INTEGRATION=false
VITE_WAVE_ACCESS_TOKEN=

VITE_ENABLE_FRESHBOOKS_INTEGRATION=false
VITE_FRESHBOOKS_CLIENT_ID=
VITE_FRESHBOOKS_CLIENT_SECRET=

# ============================================================================
# ERP/BUSINESS SYSTEM INTEGRATIONS
# ============================================================================
VITE_ENABLE_SAP_INTEGRATION=false
VITE_SAP_ENDPOINT=
VITE_SAP_CLIENT_ID=
VITE_SAP_CLIENT_SECRET=

VITE_ENABLE_ORACLE_INTEGRATION=false
VITE_ORACLE_ENDPOINT=
VITE_ORACLE_USERNAME=

VITE_ENABLE_MICROSOFT_DYNAMICS_INTEGRATION=false
VITE_DYNAMICS_ENDPOINT=
VITE_DYNAMICS_CLIENT_ID=

# ============================================================================
# COMPLIANCE & AUDIT LOGGING
# ============================================================================
VITE_ENABLE_AUDIT_LOG=true
VITE_AUDIT_LOG_RETENTION_DAYS=2555
VITE_ENABLE_COMPLIANCE_REPORTS=true
VITE_COMPLIANCE_REPORT_FORMAT=pdf,excel
VITE_ENABLE_DATA_ENCRYPTION=true
VITE_ENCRYPTION_ALGORITHM=aes-256-gcm
VITE_ENABLE_IP_WHITELISTING=false
VITE_ALLOWED_IP_ADDRESSES=

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================
VITE_ENABLE_ANALYTICS=true
VITE_ANALYTICS_PROVIDER=google
VITE_GOOGLE_ANALYTICS_ID=
VITE_MIXPANEL_TOKEN=
VITE_SENTRY_DSN=
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# ============================================================================
# RATE LIMITING & THROTTLING
# ============================================================================
VITE_ENABLE_RATE_LIMITING=true
VITE_RATE_LIMIT_REQUESTS=100
VITE_RATE_LIMIT_WINDOW_MS=900000
VITE_ENABLE_IP_THROTTLING=true
VITE_IP_THROTTLE_REQUESTS=50
VITE_IP_THROTTLE_WINDOW_MS=600000

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================
VITE_CACHE_PROVIDER=redis
VITE_REDIS_HOST=localhost
VITE_REDIS_PORT=6379
VITE_REDIS_PASSWORD=
VITE_REDIS_DB=0
VITE_CACHE_TTL=3600
VITE_ENABLE_CACHE=true

# ============================================================================
# BACKGROUND JOB PROCESSING
# ============================================================================
VITE_QUEUE_PROVIDER=bull
VITE_BULL_REDIS_URL=redis://localhost:6379
VITE_ENABLE_BACKGROUND_JOBS=true
VITE_JOB_CONCURRENCY=5
VITE_JOB_TIMEOUT=300000
VITE_INVOICE_PROCESSING_SCHEDULE=0 */6 * * *
VITE_COMPLIANCE_CHECK_SCHEDULE=0 0 * * *

# ============================================================================
# PAYMENT & BILLING
# ============================================================================
VITE_ENABLE_STRIPE=false
VITE_STRIPE_PUBLIC_KEY=
VITE_STRIPE_SECRET_KEY=

VITE_ENABLE_PAYPAL=false
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_CLIENT_SECRET=

VITE_CURRENCY_CONVERSION_API=openexchangerates
VITE_OPENEXCHANGERATES_API_KEY=
VITE_ENABLE_MULTI_CURRENCY_INVOICING=true

# ============================================================================
# REPORTING & EXPORT
# ============================================================================
VITE_ENABLE_PDF_EXPORT=true
VITE_ENABLE_EXCEL_EXPORT=true
VITE_ENABLE_CSV_EXPORT=true
VITE_ENABLE_XML_EXPORT=true
VITE_ENABLE_JSON_EXPORT=true
VITE_REPORT_GENERATION_TIMEOUT=120000
VITE_BATCH_REPORT_PROCESSING=true

# ============================================================================
# FEATURE FLAGS
# ============================================================================
VITE_FEATURE_ADVANCED_COMPLIANCE=true
VITE_FEATURE_MULTI_ENTITY_MANAGEMENT=true
VITE_FEATURE_BULK_INVOICE_PROCESSING=true
VITE_FEATURE_CUSTOM_BRANDING=false
VITE_FEATURE_WHITE_LABEL=false
VITE_FEATURE_API_ACCESS=true
VITE_FEATURE_CUSTOM_WORKFLOWS=false
VITE_FEATURE_PREDICTIVE_COMPLIANCE=false

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
VITE_FRONTEND_PORT=5173
VITE_FRONTEND_URL=http://localhost:5173
VITE_ENABLE_DARK_MODE=true
VITE_THEME_COLOR=#1F2937
VITE_ACCENT_COLOR=#3B82F6
VITE_LOCALE=en-US

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================
PORT=3000
HOST=localhost
BACKEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true
TRUST_PROXY=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
VITE_ENABLE_REQUEST_LOGGING=true
VITE_ENABLE_ERROR_LOGGING=true
VITE_LOG_RETENTION_DAYS=30

# ============================================================================
# DEMO & SANDBOX MODE
# ============================================================================
VITE_ENABLE_DEMO_MODE=false
VITE_DEMO_DATA_RESET_SCHEDULE=0 0 * * *
VITE_SANDBOX_MODE=true
VITE_SANDBOX_INVOICE_PREFIX=SANDBOX_

# ============================================================================
# LEGAL & COMPLIANCE
# ============================================================================
VITE_COMPANY_NAME=ComplianceInvoice
VITE_COMPANY_WEBSITE=https://complianceinvoice.com
VITE_PRIVACY_POLICY_URL=https://complianceinvoice.com/privacy
VITE_TERMS_OF_SERVICE_URL=https://complianceinvoice.com/terms
VITE_DATA_PROCESSING_AGREEMENT_URL=https://complianceinvoice.com/dpa
VITE_GDPR_COMPLIANCE=true
VITE_ENABLE_CONSENT_MANAGEMENT=true

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit actual credentials to version control
# 2. Use different values for development, staging, and production
# 3. For production: enable encryption, audit logging, and IP whitelisting
# 4. Ensure all integrations are tested in sandbox before enabling
# 5. Review and update supported countries based on your target markets
# 6. Configure email provider credentials for invoice delivery
# 7. Set up webhook secrets for secure integrations
# 8. Enable compliance monitoring for multi-country requirements